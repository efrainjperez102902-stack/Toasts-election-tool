    { name: "Ciales",         region: "mountain", base: { ppd:39, pnp:27, mvc:12, pip:16, pd:6 } },
    { name: "Cidra",          region: "central",  base: { ppd:33, pnp:32, mvc:15, pip:13, pd:7 } },
    { name: "Coamo",          region: "south",    base: { ppd:35, pnp:30, mvc:13, pip:14, pd:8 } },
    { name: "Comerío",        region: "mountain", base: { ppd:38, pnp:28, mvc:13, pip:15, pd:6 } },
