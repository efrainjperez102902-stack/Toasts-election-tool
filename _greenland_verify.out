    { name: "Ponce",          region: "south",    base: { ppd:35, pnp:30, mvc:14, pip:13, pd:8 } },
    { name: "Quebradillas",   region: "north",    base: { ppd:34, pnp:31, mvc:14, pip:13, pd:8 } },
