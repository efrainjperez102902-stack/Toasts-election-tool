<script>
if (!window.PR_REVAMP_ACTIVE) (function () {
  "use strict";

  // ── default parties ───────────────────────────────────────────────────────
  var ORIG_KEYS = ["ppd","pnp","mvc","pip","pd"];

  function makeDefaultParties() {
    return [
      { key: "ppd", label: "PPD", name: "Partido Popular Democrático",   color: "#d92a2a", baseStrength: 34, removable: true },
      { key: "pnp", label: "PNP", name: "Partido Nuevo Progresista",     color: "#1a52c7", baseStrength: 31, removable: true },
      { key: "mvc", label: "MVC", name: "Movimiento Victoria Ciudadana", color: "#7c3aed", baseStrength: 14, removable: true },
      { key: "pip", label: "PIP", name: "Partido Independentista P.R.",  color: "#15803d", baseStrength: 13, removable: true },
      { key: "pd",  label: "PD",  name: "Proyecto Dignidad",             color: "#c2692a", baseStrength:  8, removable: true }
    ];
  }

  // ── municipality data ────────────────────────────────────────────────────
  // base = approximate 2020 gubernatorial split (sums to 100)
  // ppd=Partido Popular, pnp=Nuevo Progresista, mvc=Victoria Ciudadana,
  // pip=Independentista, pd=Proyecto Dignidad
  var MUNIS = [
    { name: "Adjuntas",       region: "mountain", base: { ppd:39, pnp:27, mvc:12, pip:16, pd:6 } },
    { name: "Aguada",         region: "west",     base: { ppd:35, pnp:30, mvc:14, pip:13, pd:8 } },
    { name: "Aguadilla",      region: "west",     base: { ppd:34, pnp:31, mvc:14, pip:13, pd:8 } },
    { name: "Aguas Buenas",   region: "central",  base: { ppd:33, pnp:32, mvc:15, pip:13, pd:7 } },
    { name: "Aibonito",       region: "mountain", base: { ppd:38, pnp:28, mvc:13, pip:15, pd:6 } },
    { name: "Añasco",         region: "west",     base: { ppd:35, pnp:30, mvc:14, pip:13, pd:8 } },
    { name: "Arecibo",        region: "north",    base: { ppd:33, pnp:32, mvc:14, pip:13, pd:8 } },
    { name: "Arroyo",         region: "south",    base: { ppd:35, pnp:30, mvc:13, pip:14, pd:8 } },
    { name: "Barceloneta",    region: "north",    base: { ppd:33, pnp:32, mvc:14, pip:13, pd:8 } },
